{
  "name": "validations-br",
  "version": "1.6.1",
  "packageManager": "pnpm@11.9.0",
  "description": "A validator to BR informations",
  "main": "lib/index.cjs",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "repository": "https://github.com/reactivando/validations-br.git",
  "homepage": "https://github.com/reactivando/validations-br#readme",
  "author": "Reactivando <reactivando2@gmail.com>",
  "keywords": [
    "BR",
    "Brazil",
    "Validator"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint --ext .js,.jsx,.ts,.tsx ./src",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && cd examples && pnpm install --ignore-workspace && pnpm start",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "release-it": "^20.2.0",
    "release-it-pnpm": "^4.6.6",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,json,jsx,ts,tsx}": [
      "eslint",
      "prettier --check"
    ]
  }
}
